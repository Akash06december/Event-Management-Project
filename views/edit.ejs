<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Event</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: #f4f7fb;
        }

        .edit-card{
            border: none;
            border-radius: 24px;
        }

        .form-control{
            border-radius: 12px;
            padding: 12px;
        }

        .btn{
            border-radius: 12px;
            padding: 12px;
        }

    </style>

</head>

<body>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg edit-card p-5">

                <h1 class="mb-4">
                    Edit Event
                </h1>

                <form
                    action="/events/<%= foundEvent.id %>?_method=PATCH"
                    method="POST"
                >

                    <div class="mb-3">

                        <label class="form-label">
                            Title
                        </label>

                        <input
                            type="text"
                            name="title"
                            class="form-control"
                            value="<%= foundEvent.title %>"
                            required
                        >

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Description
                        </label>

                        <textarea
                            name="description"
                            class="form-control"
                            required
                        ><%= foundEvent.description %></textarea>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Date
                        </label>

                        <input
                            type="date"
                            name="date"
                            class="form-control"
                            value="<%= foundEvent.date %>"
                            required
                        >

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Venue
                        </label>

                        <input
                            type="text"
                            name="venue"
                            class="form-control"
                            value="<%= foundEvent.venue %>"
                            required
                        >

                    </div>

                    <div class="mb-4">

                        <label class="form-label">
                            Category
                        </label>

                        <input
                            type="text"
                            name="category"
                            class="form-control"
                            value="<%= foundEvent.category %>"
                            required
                        >

                    </div>

                    <button class="btn btn-dark w-100">
                        Update Event
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>

</body>

</html>