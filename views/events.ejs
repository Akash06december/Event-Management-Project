<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Campus Events</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: #f4f7fb;
        }

        .hero-section{
            background: linear-gradient(
                135deg,
                #0f172a,
                #1e293b
            );

            color: white;

            padding: 80px 0;

            border-bottom-left-radius: 40px;
            border-bottom-right-radius: 40px;

            margin-bottom: 60px;
        }

        .hero-title{
            font-size: 3.5rem;
            font-weight: 700;
        }

        .hero-text{
            font-size: 1.2rem;
            color: #cbd5e1;
        }

        .create-btn{
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 500;
        }

        .event-card{
            border: none;
            border-radius: 24px;
            transition: 0.3s ease;
            overflow: hidden;
            background: white;
        }

        .event-card:hover{
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .category-badge{
            background: #0f172a;
            color: white;
            border-radius: 50px;
            padding: 8px 16px;
            font-size: 0.8rem;
        }

        .event-title{
            font-weight: 600;
            font-size: 1.7rem;
        }

        .event-desc{
            color: #64748b;
        }

        .details-btn{
            border-radius: 12px;
            padding: 12px;
            font-weight: 500;
        }

        .info-text{
            color: #334155;
        }

    </style>

</head>

<body>

    <!-- HERO SECTION -->

    <section class="hero-section">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-lg-8">

                    <h1 class="hero-title">
                        Campus Event Management
                    </h1>

                    <p class="hero-text mt-3">
                        Discover, manage and participate in amazing college events with ease.
                    </p>

                </div>

                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">

                    <a
                        href="/events/new"
                        class="btn btn-light create-btn shadow"
                    >
                        + Create Event
                    </a>

                </div>

            </div>

        </div>

    </section>

    <!-- EVENTS -->

    <div class="container pb-5">

        <div class="row g-4">

            <% events.forEach(event => { %>

                <div class="col-lg-6">

                    <div class="card event-card shadow-sm h-100 p-4">

                        <div class="d-flex justify-content-between align-items-start">

                            <h2 class="event-title">
                                <%= event.title %>
                            </h2>

                            <span class="category-badge">
                                <%= event.category %>
                            </span>

                        </div>

                        <p class="event-desc mt-3">
                            <%= event.description %>
                        </p>

                        <div class="mt-4">

                            <p class="info-text">
                                📅 <strong>Date:</strong>
                                <%= event.date %>
                            </p>

                            <p class="info-text">
                                📍 <strong>Venue:</strong>
                                <%= event.venue %>
                            </p>

                        </div>

                        <div class="mt-auto">

                            <a
                                href="/events/<%= event.id %>"
                                class="btn btn-dark w-100 details-btn mt-3"
                            >
                                View Details
                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</body>

</html>